<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Precious Metals Trader - Live Gold, Silver & Platinum Prices</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="css/styles.css">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar">
        <div class="navbar-container">
            <div class="navbar-brand">
                <i class="fas fa-coins"></i>
                <span>Precious Metals Trader</span>
            </div>
            <div class="hamburger" id="hamburger">
                <span></span>
                <span></span>
                <span></span>
            </div>
            <ul class="navbar-menu" id="navbar-menu">
                <li><a href="#prices">Live Prices</a></li>
                <li><a href="#charts">Charts</a></li>
                <li><a href="#news">News</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <h1>Precious Metals Trading Platform</h1>
            <p>Real-time prices for Gold, Silver, Platinum & Palladium</p>
            <button class="btn btn-primary" onclick="document.getElementById('prices').scrollIntoView({behavior: 'smooth'})">
                View Live Prices
            </button>
        </div>
        <div class="hero-background">
            <div class="floating-coin gold-coin"><i class="fas fa-coins"></i></div>
            <div class="floating-coin silver-coin"><i class="fas fa-coins"></i></div>
            <div class="floating-coin platinum-coin"><i class="fas fa-coins"></i></div>
        </div>
    </section>

    <!-- Live Prices Section -->
    <section id="prices" class="prices-section">
        <div class="container">
            <h2>Live Precious Metals Prices</h2>
            <p class="section-subtitle">Updated every 60 seconds</p>
            
            <div class="update-controls">
                <button class="btn btn-secondary" onclick="updatePrices()">
                    <i class="fas fa-sync"></i> Update Now
                </button>
                <span class="last-updated">Last updated: <span id="last-updated-time">Just now</span></span>
            </div>

            <div class="prices-grid" id="prices-grid">
                <!-- Price cards will be generated by JavaScript -->
            </div>
        </div>
    </section>

    <!-- Charts Section -->
    <section id="charts" class="charts-section">
        <div class="container">
            <h2>7-Day Price Trends</h2>
            <p class="section-subtitle">Historical price movements</p>
            
            <div class="charts-grid">
                <div class="chart-container">
                    <h3>Gold (AU)</h3>
                    <canvas id="goldChart"></canvas>
                </div>
                <div class="chart-container">
                    <h3>Silver (AG)</h3>
                    <canvas id="silverChart"></canvas>
                </div>
                <div class="chart-container">
                    <h3>Platinum (PT)</h3>
                    <canvas id="platinumChart"></canvas>
                </div>
                <div class="chart-container">
                    <h3>Palladium (PD)</h3>
                    <canvas id="palladiumChart"></canvas>
                </div>
            </div>
        </div>
    </section>

    <!-- News Section -->
    <section id="news" class="news-section">
        <div class="container">
            <h2>Market News & Updates</h2>
            <p class="section-subtitle">Latest precious metals market insights</p>
            
            <div class="news-grid">
                <article class="news-card">
                    <div class="news-date">April 29, 2026</div>
                    <h3>Gold Reaches New Heights</h3>
                    <p>Gold prices surge to $2,150 per troy ounce amid economic uncertainty and strong investment demand.</p>
                    <a href="#" class="read-more">Read More <i class="fas fa-arrow-right"></i></a>
                </article>

                <article class="news-card">
                    <div class="news-date">April 28, 2026</div>
                    <h3>Silver Market Rally Continues</h3>
                    <p>Industrial demand for silver remains strong as technology sector shows robust growth prospects.</p>
                    <a href="#" class="read-more">Read More <i class="fas fa-arrow-right"></i></a>
                </article>

                <article class="news-card">
                    <div class="news-date">April 27, 2026</div>
                    <h3>Platinum Investment Opportunities</h3>
                    <p>Platinum prices offer attractive entry points for long-term investors with improving supply dynamics.</p>
                    <a href="#" class="read-more">Read More <i class="fas fa-arrow-right"></i></a>
                </article>

                <article class="news-card">
                    <div class="news-date">April 26, 2026</div>
                    <h3>Palladium Volatility Expected</h3>
                    <p>Market analysts predict increased volatility in palladium trading due to automotive sector adjustments.</p>
                    <a href="#" class="read-more">Read More <i class="fas fa-arrow-right"></i></a>
                </article>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="about-section">
        <div class="container">
            <h2>About Precious Metals Trader</h2>
            <p class="section-subtitle">Your trusted source for precious metals market data</p>
            
            <div class="about-content">
                <p>
                    Precious Metals Trader is a leading platform for tracking and analyzing precious metals prices in real-time. 
                    We provide accurate, up-to-date information on gold, silver, platinum, and palladium markets to help traders, 
                    investors, and enthusiasts make informed decisions.
                </p>
                
                <div class="features-grid">
                    <div class="feature-card">
                        <i class="fas fa-chart-line"></i>
                        <h3>Real-Time Prices</h3>
                        <p>Live price updates every minute with accurate market data</p>
                    </div>
                    <div class="feature-card">
                        <i class="fas fa-history"></i>
                        <h3>Historical Data</h3>
                        <p>Access to 7-day trend charts and historical price movements</p>
                    </div>
                    <div class="feature-card">
                        <i class="fas fa-bell"></i>
                        <h3>Market News</h3>
                        <p>Latest updates on precious metals markets and trends</p>
                    </div>
                    <div class="feature-card">
                        <i class="fas fa-mobile-alt"></i>
                        <h3>Mobile Friendly</h3>
                        <p>Access precious metals prices anytime, anywhere on any device</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact-section">
        <div class="container">
            <h2>Get In Touch</h2>
            <p class="section-subtitle">Have questions? We'd love to hear from you</p>
            
            <div class="contact-content">
                <div class="contact-info">
                    <div class="contact-item">
                        <i class="fas fa-envelope"></i>
                        <div>
                            <h4>Email</h4>
                            <p>info@preciousmetalstrader.com</p>
                        </div>
                    </div>
                    <div class="contact-item">
                        <i class="fas fa-phone"></i>
                        <div>
                            <h4>Phone</h4>
                            <p>+1 (555) 123-4567</p>
                        </div>
                    </div>
                    <div class="contact-item">
                        <i class="fas fa-map-marker-alt"></i>
                        <div>
                            <h4>Address</h4>
                            <p>123 Trading Street, New York, NY 10001</p>
                        </div>
                    </div>
                </div>

                <form class="contact-form" id="contact-form">
                    <div class="form-group">
                        <input type="text" placeholder="Your Name" required>
                    </div>
                    <div class="form-group">
                        <input type="email" placeholder="Your Email" required>
                    </div>
                    <div class="form-group">
                        <textarea placeholder="Your Message" rows="5" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Send Message</button>
                </form>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h4>About</h4>
                    <ul>
                        <li><a href="#about">About Us</a></li>
                        <li><a href="#contact">Contact</a></li>
                        <li><a href="#">Blog</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h4>Precious Metals</h4>
                    <ul>
                        <li><a href="#prices">Gold Prices</a></li>
                        <li><a href="#prices">Silver Prices</a></li>
                        <li><a href="#prices">Platinum Prices</a></li>
                        <li><a href="#prices">Palladium Prices</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h4>Follow Us</h4>
                    <div class="social-links">
                        <a href="#"><i class="fab fa-facebook"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-linkedin"></i></a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 Precious Metals Trader. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <script src="js/script.js"></script>
</body>
</html>
